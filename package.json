{
    "name": "tracker-web",
    "version": "2.0.0",
    "private": true,
    "engines": {
        "node": "20.x"
    },
    "description": "Notion-like Go tracker with React + SQLite",
    "scripts": {
        "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
        "dev:server": "node api/index.js",
        "dev:client": "vite --config client/vite.config.js",
        "build": "vite build --config client/vite.config.js",
        "start": "node api/index.js"
    },
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@mui/icons-material": "^7.3.2",
        "@mui/material": "^7.3.2",
        "@mui/x-data-grid": "^8.14.1",
        "cors": "^2.8.5",
        "csv-parse": "^5.6.0",
        "dompurify": "^3.3.3",
        "dotenv": "^17.3.1",
        "express": "^5.1.0",
        "marked": "^16.3.0",
        "mongoose": "^9.3.0",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "react-router-dom": "^7.9.3"
    },
    "devDependencies": {
        "@vitejs/plugin-react": "^5.0.4",
        "concurrently": "^9.2.1",
        "vite": "^7.1.7"
    }
}